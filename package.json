{
  "name": "eckl-eco-technics-materialverwaltung",
  "version": "0.6.9",
  "description": "Eckl Eco Technics Materialverwaltung V0.6.9 - Render Online-Probeserver",
  "main": "main.js",
  "type": "commonjs",
  "author": "Eckl Eco Technics",
  "scripts": {
    "start": "node server.js",
    "desktop": "electron .",
    "pack:win": "electron-packager . \"Eckl Eco Technics - Materialverwaltung\" --platform=win32 --arch=x64 --out=release --overwrite --asar --prune=true --ignore=\"^/release\" --ignore=\"^/node_modules/.cache\"",
